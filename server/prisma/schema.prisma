generator client {

  provider = "prisma-client-js"

}



datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



enum Role {

  STUDENT

  TEACHER

}



model User {

  id             String            @id @default(cuid())

  email          String            @unique

  username       String            @unique

  passwordHash   String

  role           Role              @default(STUDENT)

  activationKey  String?           @unique

  isActivated    Boolean           @default(false)

  activatedAt    DateTime?

  activatedBy    String?

  createdAt      DateTime          @default(now())

  updatedAt      DateTime          @updatedAt

  sessions       SessionAttempt[]

  assignments  Assignment[]      @relation("AssignmentCreatedBy")

  submissions  AssignmentSubmit[]

  challenges   Challenge[]       @relation("ChallengeCreatedBy")

  loginEvents  LoginEvent[]

  progress     UserProgress?

  timetable    UserTimetable?

  flashcards   CustomFlashcard[]

  reminders    Reminder[]

  chatHistory  AIChatMessage[]

  notes        UserNote[]

  discussions  DiscussionPost[]

  outlineProgress CourseOutlineProgress[]

}



model Subject {

  id         String     @id @default(cuid())

  label      String     @unique

  description String?

  createdAt  DateTime   @default(now())

  questions  Question[]

  assignments Assignment[]

}



model Question {

  id          String   @id @default(cuid())

  subjectId   String

  question    String

  optionA     String

  optionB     String

  optionC     String

  optionD     String

  answerIndex Int

  difficulty  String   @default("medium")

  year        Int?

  explanation String?

  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  answers     AttemptAnswer[]

}



model SessionAttempt {

  id          String          @id @default(cuid())

  userId      String

  mode        String

  score       Int

  total       Int

  percentage  Float

  durationSec Int?

  createdAt   DateTime        @default(now())

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  answers     AttemptAnswer[]

}



model AttemptAnswer {

  id         String         @id @default(cuid())

  sessionId  String

  questionId String

  selected   Int

  correct    Boolean

  confidence String?

  session    SessionAttempt @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  question   Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)

}



model Assignment {

  id          String             @id @default(cuid())

  title       String

  subjectId   String

  dueAt       DateTime?

  createdById String

  createdAt   DateTime           @default(now())

  createdBy   User               @relation("AssignmentCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  subject     Subject            @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  submits     AssignmentSubmit[]

}



model AssignmentSubmit {

  id           String      @id @default(cuid())

  assignmentId String

  studentId    String

  status       String      @default("pending")

  submittedAt  DateTime?

  assignment   Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  student      User        @relation(fields: [studentId], references: [id], onDelete: Cascade)



  @@unique([assignmentId, studentId])

}



model Challenge {

  id          String   @id @default(cuid())

  title       String

  questionIds String[]

  createdById String

  createdAt   DateTime @default(now())

  createdBy   User     @relation("ChallengeCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

}



model LoginEvent {

  id        String   @id @default(cuid())

  userId    String

  createdAt DateTime @default(now())

  ip        String?

  userAgent String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([userId, createdAt])

}



model UserProgress {

  id           String   @id @default(cuid())

  userId       String   @unique

  xp           Int      @default(0)

  sessions     Int      @default(0)

  streak       Int      @default(0)

  coins        Int      @default(0)

  weeklyGoal   Int      @default(5)

  totalCorrect Int      @default(0)

  mastery      Json     @default("{}")

  wrongCounts  Json     @default("{}")

  srData       Json     @default("{}")

  lastStudied   DateTime?

  darkMode     Boolean  @default(true)

  themePack    String   @default("aurora")

  density      String   @default("cozy")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}



model UserTimetable {

  id        String   @id @default(cuid())

  userId    String   @unique

  timetable Json     @default("{}")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}



model CustomFlashcard {

  id        String   @id @default(cuid())

  userId    String

  front     String

  back      String

  subject   String

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)


  @@index([userId])

}



model Reminder {

  id        String   @id @default(cuid())

  userId    String

  time      DateTime

  label     String

  subject   String?

  sent      Boolean  @default(false)

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)


  @@index([userId])

}



model AIChatMessage {

  id        String   @id @default(cuid())

  userId    String

  role      String

  content   String

  timestamp DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)


  @@index([userId, timestamp])

}



model UserNote {

  id        String   @id @default(cuid())

  userId    String

  subjectId String

  content   String   @default("")

  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)


  @@unique([userId, subjectId])

}



model DiscussionPost {

  id        String            @id @default(cuid())

  userId    String

  subjectId String

  text      String

  role      String            @default("Student")

  createdAt DateTime          @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  replies   DiscussionReply[]


  @@index([userId, subjectId])

}



model DiscussionReply {

  id        String   @id @default(cuid())

  postId    String

  userId    String

  text      String

  role      String   @default("Student")

  createdAt DateTime @default(now())

  post      DiscussionPost @relation(fields: [postId], references: [id], onDelete: Cascade)


  @@index([postId])

}



model CourseOutlineProgress {

  id        String   @id @default(cuid())

  userId    String

  subjectId String

  semester  String

  progress  Json     @default("{}")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)


  @@unique([userId, subjectId, semester])

}

