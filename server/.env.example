DATABASE_URL="postgresql://postgres:password@localhost:5432/scholars_circle?schema=public"
JWT_SECRET="change_me_to_a_long_secret"
PORT=4000
TEACHER_INVITE_CODE="change_me_teacher_code"
GEMINI_API_KEY="your_google_gemini_api_key_here"
OPENAI_API_KEY=""
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Paystack Payment (use sk_test_ for testing, sk_live_ for production)
PAYSTACK_SECRET_KEY="sk_test_your_paystack_secret_key_here"

# Supabase Storage (for teacher resource file uploads)
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_KEY="your_supabase_service_role_key_here"

# Security Configuration
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# For production, use:
# NODE_ENV=production
# ALLOWED_ORIGINS=https://scholarscircle.com,https://www.scholarscircle.com
# FRONTEND_URL=https://scholarscircle.com
