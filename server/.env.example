DATABASE_URL="postgresql://postgres:password@localhost:5432/scholars_circle?schema=public"
JWT_SECRET="change_me_to_a_long_secret"
PORT=4000
TEACHER_INVITE_CODE="change_me_teacher_code"
GEMINI_API_KEY="your_google_gemini_api_key_here"
OPENAI_API_KEY=""
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Paystack Payment (use sk_test_ for testing, sk_live_ for production)
PAYSTACK_SECRET_KEY="sk_test_your_paystack_secret_key_here"

# Cloudflare R2 Storage (for teacher resource file uploads)
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="resources"
# Public URL: enable R2.dev subdomain in bucket settings, or use a custom domain
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"

# Security Configuration
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# For production, use:
# NODE_ENV=production
# ALLOWED_ORIGINS=https://scholarscircle.com,https://www.scholarscircle.com
# FRONTEND_URL=https://scholarscircle.com
